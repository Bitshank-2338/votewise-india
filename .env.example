# ========================================
# Election Assistant MCP Configuration
# ========================================

# 1. Localization MCP
# Google Civic Information API Key (or equivalent)
GOOGLE_CIVIC_API_KEY="your_google_civic_api_key_here"

# 2. RAG/Knowledge MCP
# Vector Database Connection (e.g., PostgreSQL with pgvector)
DATABASE_URL="postgres://user:password@localhost:5432/election_db"

# 3. Context/Memory MCP
# Redis connection string for session state
REDIS_URL="redis://localhost:6379"
